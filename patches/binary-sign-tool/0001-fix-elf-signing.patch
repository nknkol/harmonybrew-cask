--- a/Makefile	1970-01-01 08:00:00.000000000 +0800
+++ b/Makefile	2026-06-23 18:13:01.453893906 +0800
@@ -0,0 +1,141 @@
+# Makefile for standalone compilation of binary_sign_tool
+
+PROJ := /home/user/developtools_hapsigner
+OPENSSL_PREFIX ?= /home/linuxbrew/.linuxbrew
+
+CXX := /home/linuxbrew/.linuxbrew/Cellar/gcc/15.2.0_1/bin/g++-15
+CXXFLAGS := -std=c++17 -fno-rtti -Wall -B/home/linuxbrew/.linuxbrew/Cellar/binutils/2.46.0/bin/ -include $(PROJ)/compat.h
+
+# Use Homebrew binutils 2.46 (system 2.41 doesn't support .base64 pseudo-op)
+export PATH := /home/linuxbrew/.linuxbrew/Cellar/binutils/2.46.0/bin:$(PATH)
+B := $(PROJ)/binary_sign_tool
+H := $(PROJ)/hapsigntool_cpp
+T := $(PROJ)/third_party
+BLD := $(PROJ)/build
+
+INCLUDES := \
+  -I$(B)/api/include \
+  -I$(H)/api/include \
+  -I$(B)/cmd/include \
+  -I$(H)/cmd/include \
+  -I$(B)/common/include \
+  -I$(H)/common/include \
+  -I$(B)/utils/include \
+  -I$(H)/utils/include \
+  -I$(B)/hap/entity/include \
+  -I$(B)/hap/provider/include \
+  -I$(B)/hap/sign/include \
+  -I$(B)/hap/utils/include \
+  -I$(B)/hap/verify/include \
+  -I$(H)/hap/config/include \
+  -I$(H)/hap/entity/include \
+  -I$(H)/hap/provider/include \
+  -I$(H)/hap/sign/include \
+  -I$(H)/hap/utils/include \
+  -I$(H)/hap/verify/include \
+  -I$(H)/profile/include \
+  -I$(H)/signer/include \
+  -I$(B)/codesigning/fsverity/include \
+  -I$(B)/codesigning/sign/include \
+  -I$(H)/codesigning/datastructure/include \
+  -I$(H)/codesigning/fsverity/include \
+  -I$(H)/codesigning/sign/include \
+  -I$(H)/codesigning/utils/include \
+  -I$(T)/third_party_elfio \
+  -I$(T)/third_party_elfio/elfio \
+  -I$(T)/third_party_json/single_include \
+  -I$(T)/third_party_bounds_checking_function/include \
+  -I$(T)/third_party_bounds_checking_function/src \
+  -I$(T)/third_party_zlib/contrib/minizip \
+  -I$(OPENSSL_PREFIX)/include
+
+SRCS := \
+  $(B)/main.cpp \
+  $(B)/api/src/sign_tool_service_impl.cpp \
+  $(B)/cmd/src/cmd_util.cpp \
+  $(B)/cmd/src/params_run_tool.cpp \
+  $(B)/cmd/src/params_trust_list.cpp \
+  $(H)/cmd/src/params.cpp \
+  $(B)/codesigning/fsverity/src/fs_verity_descriptor.cpp \
+  $(H)/codesigning/fsverity/src/fs_verity_digest.cpp \
+  $(B)/codesigning/fsverity/src/fs_verity_generator.cpp \
+  $(H)/codesigning/fsverity/src/fs_verity_hash_algorithm.cpp \
+  $(B)/codesigning/fsverity/src/merkle_tree_builder.cpp \
+  $(H)/codesigning/fsverity/src/fs_verity_descriptor_with_sign.cpp \
+  $(H)/codesigning/utils/src/fs_digest_utils.cpp \
+  $(H)/codesigning/utils/src/cms_utils.cpp \
+  $(H)/codesigning/sign/src/bc_signeddata_generator.cpp \
+  $(B)/codesigning/sign/src/code_signing.cpp \
+  $(H)/common/src/byte_buffer.cpp \
+  $(H)/common/src/digest_parameter.cpp \
+  $(H)/common/src/digest_common.cpp \
+  $(H)/common/src/localization_adapter.cpp \
+  $(B)/common/src/options.cpp \
+  $(H)/hap/config/src/signer_config.cpp \
+  $(H)/hap/entity/src/content_digest_algorithm.cpp \
+  $(B)/hap/entity/src/param_constants.cpp \
+  $(H)/hap/entity/src/signature_algorithm_helper.cpp \
+  $(B)/hap/provider/src/self_sign_sign_provider.cpp \
+  $(B)/hap/provider/src/local_sign_provider.cpp \
+  $(H)/hap/provider/src/remote_sign_provider.cpp \
+  $(B)/hap/provider/src/sign_provider.cpp \
+  $(B)/hap/sign/src/sign_elf.cpp \
+  $(B)/hap/verify/src/verify_elf.cpp \
+  $(H)/hap/utils/src/dynamic_lib_handle.cpp \
+  $(B)/hap/sign/src/bc_pkcs7_generator.cpp \
+  $(B)/profile/src/profile_info.cpp \
+  $(H)/profile/src/profile_verify.cpp \
+  $(H)/profile/src/pkcs7_data.cpp \
+  $(B)/profile/src/profile_sign_tool.cpp \
+  $(H)/signer/src/local_signer.cpp \
+  $(H)/signer/src/signer_factory.cpp \
+  $(H)/utils/src/verify_cert_openssl_utils.cpp \
+  $(B)/utils/src/file_utils.cpp \
+  $(H)/utils/src/key_store_helper.cpp \
+  $(H)/utils/src/string_utils.cpp \
+  $(H)/utils/src/verify_hap_openssl_utils.cpp
+
+# bounds_checking_function sources
+SEC_SRCS := \
+  $(T)/third_party_bounds_checking_function/src/memcpy_s.c \
+  $(T)/third_party_bounds_checking_function/src/memset_s.c \
+  $(T)/third_party_bounds_checking_function/src/sprintf_s.c \
+  $(T)/third_party_bounds_checking_function/src/snprintf_s.c \
+  $(T)/third_party_bounds_checking_function/src/vsprintf_s.c \
+  $(T)/third_party_bounds_checking_function/src/vsnprintf_s.c \
+  $(T)/third_party_bounds_checking_function/src/strcpy_s.c \
+  $(T)/third_party_bounds_checking_function/src/strcat_s.c \
+  $(T)/third_party_bounds_checking_function/src/strncat_s.c \
+  $(T)/third_party_bounds_checking_function/src/strncpy_s.c \
+  $(T)/third_party_bounds_checking_function/src/securecutil.c \
+  $(T)/third_party_bounds_checking_function/src/secureprintoutput_a.c
+
+OBJS := $(patsubst %.cpp, $(BLD)/%.o, $(SRCS))
+SEC_OBJS := $(patsubst %.c, $(BLD)/%.o, $(SEC_SRCS))
+
+LDFLAGS := -L$(OPENSSL_PREFIX)/lib -lssl -lcrypto -ldl
+
+TARGET := $(BLD)/binary-sign-tool
+
+.PHONY: all clean
+
+all: $(TARGET)
+
+# Rule for .cpp -> .o
+$(BLD)/%.o: %.cpp
+	@mkdir -p $(dir $@)
+	@echo "[CXX] $<"
+	@$(CXX) $(CXXFLAGS) $(INCLUDES) -c $< -o $@
+
+# Rule for .c -> .o
+$(BLD)/%.o: %.c
+	@mkdir -p $(dir $@)
+	@echo "[CC]  $<"
+	@$(CXX) $(CXXFLAGS) $(INCLUDES) -c $< -o $@
+
+$(TARGET): $(OBJS) $(SEC_OBJS)
+	@echo "[LD]  $@"
+	@$(CXX) $(CXXFLAGS) $^ $(LDFLAGS) -o $@
+
+clean:
+	rm -rf $(BLD)
