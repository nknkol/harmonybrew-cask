-        // Create info from bind and type
-        public static byte makeInfo(byte bind, byte type) {
-            return (byte) ((bind << 4) | (type & 0xF));
-        }
-
-        // Create visibility
-        public static byte makeVisibility(byte visibility) {
-            return (byte) (visibility & 0x3);
-        }
-    }
