+     * Get int value of key.
+     *
+     * @param key      key
+     * @param defValue defValue
+     * @return Value of key
+     */
+    public int getInt(String key, int defValue) {
+        Object value = this.get(key);
+        if (value instanceof Integer) {
+            return (int) value;
+        }
