+
+    private static Map<Long, String> createDynamicTagNames() {
+        Map<Long, String> names = new HashMap<>();
+        names.put(0L, "NULL");
+        names.put(1L, "NEEDED");
+        names.put(2L, "PLTRELSZ");
+        names.put(3L, "PLTGOT");
+        names.put(4L, "HASH");
+        names.put(5L, "STRTAB");
+        names.put(6L, "SYMTAB");
+        names.put(7L, "RELA");
+        names.put(8L, "RELASZ");
