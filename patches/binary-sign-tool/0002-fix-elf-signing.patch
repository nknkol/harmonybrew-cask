-
-        for (int i = 0; i < num; i++) {
-            Section sec = new Section(header.getFileClass(), header.getConvertor(), header.getAddrTranslator(),
-                compression);
-            sec.setIndex(i);
-            sec.setLazy(isLazy);
-            sec.load(fc, offset + (long) i * entrySize);
