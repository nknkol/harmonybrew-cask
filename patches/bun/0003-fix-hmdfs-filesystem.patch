+fn classifySymlink(path: string, target: string, is_file: bool) FileSystem.Entry.SymlinkKind {
+    if (!is_file) return .real;
+
+    const bin_segment = std.fs.path.sep_str ++ ".bin" ++ std.fs.path.sep_str;
+    if (strings.indexOf(path, bin_segment) != null) return .real;
