@@ -4386,3 +4394,14 @@ const strings = bun.strings;
 
 const logger = bun.logger;
 const Msg = logger.Msg;
+
+fn shouldPreserveBunInstallSymlink(path: string, target: string) bool {
+    const node_modules_segment = std.fs.path.sep_str ++ "node_modules" ++ std.fs.path.sep_str;
+    if (strings.indexOf(path, node_modules_segment) == null) return false;
+
+    const bin_segment = std.fs.path.sep_str ++ ".bin" ++ std.fs.path.sep_str;
+    if (strings.indexOf(path, bin_segment) != null) return false;
+
+    const bun_install_cache_segment = std.fs.path.sep_str ++ ".bun" ++ std.fs.path.sep_str ++ "install" ++ std.fs.path.sep_str ++ "cache" ++ std.fs.path.sep_str;
+    return strings.indexOf(target, bun_install_cache_segment) != null;
+}
