 const default_allocator = bun.default_allocator;
 const strings = bun.strings;
+
+fn classifySymlink(path: string, target: string, is_file: bool) FileSystem.DirEntry.Entry.SymlinkKind {
+    if (!is_file) return .real;
+    if (!pathContainsNodeModulesSegment(path)) return .real;
+
+    const node_bin_segment = std.fs.path.sep_str ++ "node_modules" ++ std.fs.path.sep_str ++ ".bin" ++ std.fs.path.sep_str;
+    if (strings.indexOf(path, node_bin_segment) != null or
+        std.mem.startsWith(u8, path, "node_modules" ++ std.fs.path.sep_str ++ ".bin" ++ std.fs.path.sep_str))
+        return .real;
+
+    const bun_install_cache_segment = std.fs.path.sep_str ++ ".bun" ++ std.fs.path.sep_str ++ "install" ++ std.fs.path.sep_str ++ "cache" ++ std.fs.path.sep_str;
+    if (strings.indexOf(target, bun_install_cache_segment) != null) return .hardlink_fallback;
+
+    return .real;
+}
+
+fn pathContainsNodeModulesSegment(path: string) bool {
+    const node_modules_segment = std.fs.path.sep_str ++ "node_modules" ++ std.fs.path.sep_str;
+    return strings.indexOf(path, node_modules_segment) != null or
+        std.mem.startsWith(u8, path, "node_modules" ++ std.fs.path.sep_str);
+}
