+fn harmonyDebugSymlinkDecision(comptime label: string, logical_path: string, target_path: string, symlink_kind: string, preserve: bool) void {
+    if (!bun.getenvTruthy("BUN_HARMONY_DEBUG_RESOLVER")) return;
+    if (!harmonyDebugShouldLogSymlink(logical_path, target_path)) return;
+
+    std.debug.print(
+        "[bun-harmony-debug] resolver.{s} logical=\"{s}\" target=\"{s}\" symlink_kind={s} preserve={}\n",
+        .{ label, logical_path, target_path, symlink_kind, preserve },
+    );
+}
+
+fn harmonyDebugShouldLogSymlink(logical_path: string, target_path: string) bool {
+    const bun_install_cache_segment = std.fs.path.sep_str ++ ".bun" ++ std.fs.path.sep_str ++ "install" ++ std.fs.path.sep_str ++ "cache" ++ std.fs.path.sep_str;
+    if (strings.indexOf(logical_path, bun_install_cache_segment) == null and
+        strings.indexOf(target_path, bun_install_cache_segment) == null)
+        return false;
+
+    return pathContainsNodeModulesSegment(logical_path) or pathContainsNodeModulesSegment(target_path);
+}
