+    if (!harmonyDebugIsEnabled()) return;
+    if (!harmonyDebugShouldLogPath(path.text, path.pretty, source_dir) and
+        !harmonyDebugShouldLogPath(resolved_text, resolved_pretty, source_dir) and
+        !isPackagePath(import_path))
+        return;
+
+    std.debug.print(
+        "[bun-harmony-debug] bundler.{s} source=\"{s}\" pretty=\"{s}\" source_dir=\"{s}\" import=\"{s}\" resolved=\"{s}\" resolved_pretty=\"{s}\" kind={s} target={s}\n",
+        .{ label, path.text, path.pretty, source_dir, import_path, resolved_text, resolved_pretty, @tagName(import_kind), @tagName(target) },
