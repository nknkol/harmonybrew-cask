 const string = []const u8;
 
+fn harmonyDebugBundlerSource(path: Fs.Path, source_dir: string, target: options.Target) void {
+    if (!harmonyDebugIsEnabled() or !harmonyDebugShouldLogPath(path.text, path.pretty, source_dir)) return;
+
+    std.debug.print(
+        "[bun-harmony-debug] bundler.source source=\"{s}\" pretty=\"{s}\" source_dir=\"{s}\" target={s}\n",
+        .{ path.text, path.pretty, source_dir, @tagName(target) },
+    );
+}
+
+fn harmonyDebugBundlerImport(path: Fs.Path, source_dir: string, import_path: string, import_kind: ImportKind, target: options.Target) void {
+    if (!harmonyDebugIsEnabled() or !harmonyDebugShouldLogPath(path.text, path.pretty, source_dir) or !isPackagePath(import_path)) return;
+
+    std.debug.print(
+        "[bun-harmony-debug] bundler.resolve_from_cache source=\"{s}\" pretty=\"{s}\" source_dir=\"{s}\" import=\"{s}\" kind={s} target={s}\n",
+        .{ path.text, path.pretty, source_dir, import_path, @tagName(import_kind), @tagName(target) },
+    );
+}
+
+fn harmonyDebugRunResolver(comptime label: string, source_file: string, source_dir: string, resolved_text: string, resolved_pretty: string, specifier: string, import_kind: ImportKind, target: options.Target) void {
+    if (!harmonyDebugIsEnabled()) return;
+    if (!harmonyDebugShouldLogPath(source_file, source_dir, resolved_text) and
+        !harmonyDebugShouldLogPath(resolved_text, resolved_pretty, source_dir) and
+        !isPackagePath(specifier))
+        return;
+
+    std.debug.print(
+        "[bun-harmony-debug] bundler.{s} source_file=\"{s}\" source_dir=\"{s}\" resolved=\"{s}\" pretty=\"{s}\" import=\"{s}\" kind={s} target={s}\n",
+        .{ label, source_file, source_dir, resolved_text, resolved_pretty, specifier, @tagName(import_kind), @tagName(target) },
+    );
+}
+
+fn harmonyDebugIsEnabled() bool {
+    return bun.getenvTruthy("BUN_HARMONY_DEBUG_RESOLVER");
+}
+
+fn harmonyDebugIsBunInstallCachePath(path: string) bool {
+    const bun_install_cache_segment = std.fs.path.sep_str ++ ".bun" ++ std.fs.path.sep_str ++ "install" ++ std.fs.path.sep_str ++ "cache" ++ std.fs.path.sep_str;
+    return strings.indexOf(path, bun_install_cache_segment) != null;
+}
+
+fn harmonyDebugIsNodeModulesPath(path: string) bool {
+    const node_modules_segment = std.fs.path.sep_str ++ "node_modules" ++ std.fs.path.sep_str;
+    return strings.indexOf(path, node_modules_segment) != null or
+        std.mem.startsWith(u8, path, "node_modules" ++ std.fs.path.sep_str);
+}
+
+fn harmonyDebugShouldLogPath(a: string, b: string, c: string) bool {
+    return harmonyDebugIsBunInstallCachePath(a) or harmonyDebugIsBunInstallCachePath(b) or harmonyDebugIsBunInstallCachePath(c) or
+        harmonyDebugIsNodeModulesPath(a) or harmonyDebugIsNodeModulesPath(b) or harmonyDebugIsNodeModulesPath(c);
+}
