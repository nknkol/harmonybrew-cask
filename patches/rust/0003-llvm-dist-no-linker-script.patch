--- a/src/bootstrap/src/core/build_steps/dist.rs	2026-05-26 07:21:07.000000000 +0800
+++ b/src/bootstrap/src/core/build_steps/dist.rs	2026-06-29 03:04:15.527456719 +0800
@@ -2422,7 +2422,13 @@
         builder.install(&t!(fs::canonicalize(source)), destination, FileType::NativeLibrary);
 
         let full_dest = destination.join(source.file_name().unwrap());
-        if install_symlink {
+        let is_ohos = builder.config.host_target.to_string().ends_with("-ohos");
+        if is_ohos {
+            // HarmonyOS's dynamic loader does not understand GNU ld-style linker scripts like
+            // `INPUT(libLLVM.so)`, and dist tarballs also reject symlinks, so materialize the
+            // alias as a real shared library file.
+            builder.copy_link(&t!(fs::canonicalize(source)), &full_dest, FileType::NativeLibrary);
+        } else if install_symlink {
             // For download-ci-llvm, also install the symlink, to match what LLVM does. Using a
             // symlink is fine here, as this is not a rustup component.
             builder.copy_link(source, &full_dest, FileType::NativeLibrary);
